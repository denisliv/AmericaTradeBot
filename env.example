# Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# Database Configuration (PostgreSQL)
POSTGRES_DB=america_trade
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
# Размер пула соединений (по умолчанию 5..20). Поднимайте под нагрузку.
POSTGRES_POOL_MIN_SIZE=5
POSTGRES_POOL_MAX_SIZE=20

REDIS_DATABASE=0
REDIS_PROMO_DATABASE=1
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Copart Configuration
COPART_URL=https://www.copart.com

# OpenAI Configuration
# API_KEY обязателен — приложение не стартует без него.
API_KEY=
BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-5-mini

# OpenAI Embeddings Configuration
EMBEDDINGS_API_KEY=your_openai_api_key_here
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_MODEL_NAME=text-embedding-3-small

# AI Manager
AI_MANAGER_MAX_HISTORY_MESSAGES=20
AI_MANAGER_RAG_TOP_K=4
AI_MANAGER_RAG_SCORE_THRESHOLD=0.65
AI_MANAGER_FAISS_INDEX_PATH=data/vectorstore/ai_manager
AI_MANAGER_KNOWLEDGE_FILE=data/ai_manager/agent.md

# Bitrix
BITRIX_WEBHOOK_URL=https://your-company.bitrix24.by/rest/user_id/webhook_token
BITRIX_SOURCE=AI Manager (Telegram)

# Grafana
# ──────────────────────────────────────────────────────────────────────────────
# Дефолтные значения — для локального запуска (docker compose up локально на
# вашей машине, открываете http://localhost:3000).
#
# На сервере через SSH-туннель — оставьте те же значения. Каждый админ открывает
# туннель командой: ssh -L 3000:localhost:3000 user@<droplet-ip>
# После этого http://localhost:3000 у админа на машине пробрасывается на Grafana.
#
# Для публичного nip.io/домена — поменяйте на https://<host>/... и установите
# GRAFANA_COOKIE_SECURE=true (чтобы cookies требовали HTTPS).
# ──────────────────────────────────────────────────────────────────────────────
GRAFANA_PUBLIC_URL=http://localhost:3000/d/americatrade-overview
GRAFANA_PUBLIC_URL_BASE=http://localhost:3000
GRAFANA_COOKIE_SECURE=false
# Логин/пароль владельца Grafana. На локалке оставьте admin/admin, в проде —
# уникальный сложный пароль. Дополнительных пользователей создадите в UI.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s.%(msecs)03d - %(name)s - %(levelname)s - %(message)s

# --- Docker Compose (docker compose up) ---
# Имена сервисов из docker-compose подставляются в окружение сервиса bot автоматически;
# в .env всё равно удобно держать согласованные значения:
# POSTGRES_HOST=postgres
# REDIS_HOST=redis
# Пароль Redis: в шаблоне docker-compose Redis без auth внутри сети — оставьте REDIS_PASSWORD пустым
# или настройте отдельно (тогда нужен redis-server --requirepass и те же креды в приложении).
