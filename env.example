# Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# Database Configuration (PostgreSQL)
POSTGRES_DB=america_trade
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
# Размер пула соединений (по умолчанию 5..20). Поднимайте под нагрузку.
POSTGRES_POOL_MIN_SIZE=5
POSTGRES_POOL_MAX_SIZE=20

REDIS_DATABASE=0
REDIS_PROMO_DATABASE=1
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Copart Configuration
COPART_URL=https://www.copart.com

# Bitrix
BITRIX_WEBHOOK_URL=https://your-company.bitrix24.by/rest/user_id/webhook_token

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s.%(msecs)03d - %(name)s - %(levelname)s - %(message)s

# --- Docker Compose (docker compose up) ---
# Имена сервисов из docker-compose подставляются в окружение сервиса bot автоматически;
# в .env всё равно удобно держать согласованные значения:
# POSTGRES_HOST=postgres
# REDIS_HOST=redis
# Пароль Redis: в шаблоне docker-compose Redis без auth внутри сети — оставьте REDIS_PASSWORD пустым
# или настройте отдельно (тогда нужен redis-server --requirepass и те же креды в приложении).
